# =============================================================
# nimi-web — environment template
# Copy this file to `.env.local` and fill in real values.
# =============================================================

NODE_ENV=development

# Public (sent to the browser — never put secrets here)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Server-only (used in Server Components and Route Handlers)
INTERNAL_API_URL=http://localhost:3001
SENTRY_DSN=

# Cloudflare R2 — image uploads from the admin UI
# (admin → menu → upload from device)
# All five must be set for uploads to succeed. Local dev without R2 still
# boots; the upload route returns a friendly 500 and the admin can paste
# a remote URL instead.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL with no trailing slash, e.g. https://pub-xxxxx.r2.dev
# or https://images.nimievents.com if a custom domain is connected.
R2_PUBLIC_URL=
